getter HTMLElement::style()
%{
	slatejs_push_this(ctx);
	slatejs_get_prop_string(ctx, -1, MAGIC(style));
	if (slatejs_is_undefined(ctx, -1)) {
		slatejs_pop(ctx);
		slatejs_push_pointer(ctx, (dom_element *)priv->parent.parent.node);
		if (slatejs_bind_create_object(ctx, PROTO_NAME(CSSSTYLEDECLARATION), 1) != SLATEJS_EXEC_SUCCESS) {
			return 0;
		}
		slatejs_dup(ctx, -1);
		slatejs_put_prop_string(ctx, -3, MAGIC(style));
	}
	return 1;
%}
