init MouseEvent(struct dom_mouse_event *evt::evt);

getter MouseEvent::screenX()
%{
	int32_t value = 0;
	if (dom_mouse_event_get_screen_x(priv->parent.parent.evt, &value) !=
			DOM_NO_ERR) {
		return 0;
	}
	slatejs_push_int(ctx, value);
	return 1;
%}

