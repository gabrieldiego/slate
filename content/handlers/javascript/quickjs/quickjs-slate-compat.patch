+static double slate_quickjs_trunc(double x)
+{
+    return x < 0 ? ceil(x) : floor(x);
+}
+
+static double slate_quickjs_expm1(double x)
+{
+    return exp(x) - 1.0;
+}
+
+static double slate_quickjs_log1p(double x)
+{
+    return log(1.0 + x);
+}
+
+static double slate_quickjs_log2(double x)
+{
+    return log(x) / log(2.0);
+}
+
+static double slate_quickjs_cbrt(double x)
+{
+    return x < 0 ? -pow(-x, 1.0 / 3.0) : pow(x, 1.0 / 3.0);
+}
+
+static double slate_quickjs_round(double x)
+{
+    return x < 0 ? ceil(x - 0.5) : floor(x + 0.5);
+}
+
+static long slate_quickjs_lrint(double x)
+{
+    double f = floor(x);
+    double d = x - f;
+    long i;
+
+    if (d > 0.5)
+        return (long)(f + 1.0);
+    if (d < 0.5)
+        return (long)f;
+
+    i = (long)f;
+    return (i & 1) ? i + 1 : i;
+}
+
+static double slate_quickjs_fmin(double a, double b)
+{
+    return a < b ? a : b;
+}
+
+static double slate_quickjs_fmax(double a, double b)
+{
+    return a > b ? a : b;
+}
+
